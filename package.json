{
  "name": "commitsense-vscode-ext",
  "displayName": "CommitSense",
  "description": "Generate meaningul Git commit messages based on staged changes.",
  "version": "1.0.0",
  "publisher": "harshrajeshnaikdhure",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "git",
    "commit",
    "conventional commits"
  ],
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/unusual-me/CommitSense.git"
  },
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commitSense.generateCommitMessage",
        "title": "CommitSense: Generate Commit Message"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "18.x"
  }
}
